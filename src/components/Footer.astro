---
import Icon from './Icon.astro';
import { getSiteConfig } from '../data/site';

const today = new Date();
const { profile, site } = await getSiteConfig();
const hasSocialLinks = Boolean(profile.website || profile.github || profile.email);
---

<footer>
  &copy; {today.getFullYear()}
  {site.title}. {site.footerNote}
  {
    hasSocialLinks && (
      <div class="social-links">
        {profile.website && (
          <a href={profile.website} target="_blank" rel="noreferrer">
            <span class="sr-only">Open website</span>
            <Icon name="compass" size={18} />
          </a>
        )}
        {profile.github && (
          <a href={profile.github} target="_blank" rel="noreferrer">
            <span class="sr-only">Open GitHub profile</span>
            <Icon name="github" size={18} />
          </a>
        )}
        {profile.email && (
          <a href={`mailto:${profile.email}`}>
            <span class="sr-only">Email</span>
            <Icon name="mail" size={18} />
          </a>
        )}
      </div>
    )
  }
</footer>
<style>
  footer {
    padding: 3em 1em 6em;
    color: var(--paper-ink-faint);
    font-size: 0.88rem;
    text-align: center;
  }
  .social-links {
    display: flex;
    justify-content: center;
    gap: 1em;
    margin-top: 1em;
  }
  .social-links a {
    display: inline-grid;
    place-items: center;
    width: 40px;
    height: 40px;
    text-decoration: none;
    color: var(--paper-ink-soft);
  }
  .social-links a:hover {
    color: var(--paper-accent);
  }
</style>

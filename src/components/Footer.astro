---
import { getSiteConfig } from '../data/site';

const today = new Date();
const { site } = await getSiteConfig();
const { showTemplateCredit = false } = Astro.props;
---

<footer>
  <p>&copy; {today.getFullYear()} {site.title}. {site.footerNote}</p>
  {
    showTemplateCredit && site.templateCredit && (
      <p class="template-credit">
        <a href={site.templateCreditHref || '#'} target="_blank" rel="noreferrer">
          {site.templateCredit}
        </a>
      </p>
    )
  }
</footer>
<style>
  footer {
    padding: 3em 1em 6em;
    color: var(--paper-ink-faint);
    font-size: 0.88rem;
    text-align: center;
  }
  p {
    margin: 0;
  }
  .template-credit {
    margin-top: 0.45rem;
  }
  .template-credit a {
    text-decoration: none;
    color: inherit;
  }
  .template-credit a:hover {
    color: var(--paper-accent);
  }
</style>

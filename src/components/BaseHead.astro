---
// Import the global.css file here so that it is included on
// all pages through the use of the <BaseHead /> component.
import '../styles/global.css';
import type { ImageMetadata } from 'astro';
import FallbackImage from '../assets/figure/fail-loading-image.png';
import { getSiteConfig } from '../data/site';
import { withBasePath } from '../utils/base-path';
import { ClientRouter } from 'astro:transitions';

interface Props {
  title: string;
  description: string;
  image?: ImageMetadata | string;
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const { title, description, image = FallbackImage } = Astro.props;
const imageUrl = typeof image === 'string' ? image : image.src;
const { site } = await getSiteConfig();
---

<!-- Global Metadata -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<script is:inline>
  (() => {
    const storageKey = 'wuwuyn-theme';
    const root = document.documentElement;
    const systemTheme = () =>
      window.matchMedia?.('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
    const storedTheme = () => {
      try {
        return localStorage.getItem(storageKey);
      } catch {
        return null;
      }
    };
    const theme = storedTheme() || systemTheme();

    root.dataset.theme = theme;
    root.style.colorScheme = theme;

    if (!window.__wuwuynThemePreflightInitialized) {
      window.__wuwuynThemePreflightInitialized = true;

      document.addEventListener('astro:before-swap', (event) => {
        const currentTheme = root.dataset.theme || storedTheme() || systemTheme();
        const nextRoot = event.newDocument.documentElement;
        const nextThemeMeta = event.newDocument.querySelector('meta[name="theme-color"]');

        nextRoot.dataset.theme = currentTheme;
        nextRoot.style.colorScheme = currentTheme;
        nextThemeMeta?.setAttribute('content', currentTheme === 'dark' ? '#171b18' : '#fdfdf9');
      });
    }
  })();
</script>
<ClientRouter fallback="swap" />
<script is:inline>
  (() => {
    const storageKey = 'wuwuyn-theme';
    const root = document.documentElement;
    const themeMeta = () => document.querySelector('meta[name="theme-color"]');
    const systemTheme = () =>
      window.matchMedia?.('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
    const storedTheme = () => {
      try {
        return localStorage.getItem(storageKey);
      } catch {
        return null;
      }
    };
    const setStoredTheme = (theme) => {
      try {
        localStorage.setItem(storageKey, theme);
      } catch {}
    };
    const applyTheme = (theme, persist = true) => {
      const nextTheme = theme === 'dark' ? 'dark' : 'light';
      const toggleLabel = nextTheme === 'dark' ? 'Switch to light theme' : 'Switch to dark theme';

      root.dataset.theme = nextTheme;
      root.style.colorScheme = nextTheme;
      themeMeta()?.setAttribute('content', nextTheme === 'dark' ? '#171b18' : '#fdfdf9');
      for (const button of document.querySelectorAll('[data-theme-toggle]')) {
        button.setAttribute('aria-label', toggleLabel);
        button.setAttribute('title', toggleLabel);
      }
      if (persist) setStoredTheme(nextTheme);
    };
    const syncThemeControls = () => {
      applyTheme(root.dataset.theme || storedTheme() || systemTheme(), false);
    };

    applyTheme(storedTheme() || systemTheme(), false);

    if (!window.__wuwuynTheme) {
      window.__wuwuynTheme = {
        toggle() {
          applyTheme(root.dataset.theme === 'dark' ? 'light' : 'dark');
        },
      };
    }

    if (window.__wuwuynThemeInitialized) {
      syncThemeControls();
      return;
    }

    window.__wuwuynThemeInitialized = true;

    document.addEventListener('click', (event) => {
      const toggle = event.target.closest?.('[data-theme-toggle]');
      if (toggle) window.__wuwuynTheme.toggle();
    });

    document.addEventListener('DOMContentLoaded', syncThemeControls, { once: true });
    document.addEventListener('astro:page-load', syncThemeControls);

    window.matchMedia?.('(prefers-color-scheme: dark)').addEventListener('change', (event) => {
      if (!storedTheme()) applyTheme(event.matches ? 'dark' : 'light', false);
    });
  })();
</script>
<link rel="icon" type="image/png" href={withBasePath('images/avatar-cat.png')} />
<link rel="apple-touch-icon" href={withBasePath('images/avatar-cat.png')} />
<link rel="manifest" href={withBasePath('manifest.json')} />
<meta name="theme-color" content="#fdfdf9" />
<link rel="sitemap" href={withBasePath('sitemap-index.xml')} />
<link
  rel="alternate"
  type="application/rss+xml"
  title={site.title}
  href={new URL(withBasePath('rss.xml'), Astro.site)}
/>
<meta name="generator" content={Astro.generator} />

<!-- Canonical URL -->
<link rel="canonical" href={canonicalURL} />

<!-- Primary Meta Tags -->
<title>{title}</title>
<meta name="title" content={title} />
<meta name="description" content={description} />

<!-- Open Graph / Facebook -->
<meta property="og:type" content="website" />
<meta property="og:url" content={Astro.url} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={new URL(imageUrl, Astro.url)} />

<!-- Twitter -->
<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content={Astro.url} />
<meta property="twitter:title" content={title} />
<meta property="twitter:description" content={description} />
<meta property="twitter:image" content={new URL(imageUrl, Astro.url)} />
